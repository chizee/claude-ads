{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AI-Marketing-Hub/claude-ads/schemas/orchestration-packet.v1.json",
  "title": "Claude Ads orchestration task packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "task_id", "run_id", "role", "objective", "scope",
    "exclusions", "evidence_policy", "privacy_class", "mutation_authority",
    "inputs", "output_contract", "verification", "recovery", "status"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "run_id": {"type": "string", "pattern": "^[a-zA-Z0-9._-]+$"},
    "role": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "exclusions": {"type": "array", "items": {"type": "string"}},
    "evidence_policy": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "privacy_class": {"enum": ["public", "internal", "confidential", "restricted"]},
    "mutation_authority": {"enum": ["none", "repository-only", "draft-external", "approved-external"]},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "destination", "single_writer"],
      "properties": {
        "schema": {"type": "string", "minLength": 1},
        "destination": {"type": "string", "minLength": 1},
        "single_writer": {"type": "boolean"}
      }
    },
    "verification": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "recovery": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "status": {"enum": ["queued", "active", "blocked", "completed", "rejected"]}
  }
}
